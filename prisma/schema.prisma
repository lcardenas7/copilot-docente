// Copilot del Docente - Database Schema
// PostgreSQL with Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  TEACHER
  STUDENT
  ADMIN
}

enum Plan {
  FREE
  PRO
  SCHOOL
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_ANSWER
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  ORDERING
  SHORT_ANSWER
  OPEN
}

enum Methodology {
  TRADITIONAL
  PBL
  FLIPPED
  COLLABORATIVE
  GAMIFICATION
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EventType {
  EXAM
  PERIOD_END
  BIRTHDAY
  EVENT
  PERSONAL
  HOLIDAY
}

enum SubmissionStatus {
  PENDING
  AUTO_GRADED
  NEEDS_REVIEW
  GRADED
}

enum AIGenerationType {
  GUIDE
  EXAM
  RUBRIC
  ACTIVITY
  COPILOT
}

// ==================== AUTH (NextAuth.js) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== USERS ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          Role      @default(TEACHER)
  plan          Plan      @default(FREE)
  schoolId      String?   @map("school_id")
  birthDate     DateTime? @map("birth_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  accounts       Account[]
  sessions       Session[]
  school         School?         @relation(fields: [schoolId], references: [id])
  guides         Guide[]
  exams          Exam[]
  questions      Question[]
  classrooms     Classroom[]
  enrollments    Enrollment[]
  submissions    Submission[]
  notifications  Notification[]
  subscription   Subscription?
  usageLimits    UsageLimit[]
  aiGenerations  AIGeneration[]
  templates      Template[]
  
  // New relations for Fase 1
  academicPeriods AcademicPeriod[]
  schoolProfile  SchoolProfile?
  gradeBooks     GradeBook[]
  attendanceRecords Attendance[]
  calendarEvents CalendarEvent[]
  teacherLogs    TeacherLog[] @relation("TeacherLogs")
  studentLogs    TeacherLog[] @relation("StudentLogs")
  recaudos       Recaudo[]
  recaudoResponses RecaudoResponse[]

  @@map("users")
}

model School {
  id        String   @id @default(cuid())
  name      String
  country   String   @default("CO")
  city      String?
  plan      Plan     @default(SCHOOL)
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("schools")
}

// ==================== CONTENT ====================

model Guide {
  id          String      @id @default(cuid())
  teacherId   String      @map("teacher_id")
  classroomId String?     @map("classroom_id")
  topicId     String?     @map("topic_id")
  title       String
  subject     String
  grade       String
  topicName   String      @map("topic_name") // Legacy field for topic name
  duration    Int         @default(60) // minutes
  methodology Methodology @default(TRADITIONAL)
  bloomLevel  BloomLevel  @default(UNDERSTAND)
  objectives  Json        // Array of objectives
  activities  Json        // Array of activities
  evaluation  Json?       // Evaluation criteria
  resources   Json?       // Suggested resources
  isPublic    Boolean     @default(false) @map("is_public")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom?   @relation(fields: [classroomId], references: [id])
  topic       Topic?       @relation(fields: [topicId], references: [id])
  assignments Assignment[]

  @@map("guides")
}

model Exam {
  id          String     @id @default(cuid())
  teacherId   String     @map("teacher_id")
  classroomId String?    @map("classroom_id")
  topicId     String?    @map("topic_id")
  title       String
  subject     String
  grade       String
  topicName   String?    @map("topic_name") // Legacy field for topic name
  difficulty  Difficulty @default(MEDIUM)
  timeLimit   Int?       // minutes
  questions   Json       // Array of questions with answers
  isPublic    Boolean    @default(false) @map("is_public")
  isPublished Boolean    @default(false) @map("is_published")
  publishedAt DateTime?  @map("published_at")
  deadline    DateTime?
  accessCode  String?    @unique @map("access_code") // For student access
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom?   @relation(fields: [classroomId], references: [id])
  topic       Topic?       @relation(fields: [topicId], references: [id])
  assignments Assignment[]
  gradeBooks  GradeBook[]
  calendarEvents CalendarEvent[]

  @@map("exams")
}

model Question {
  id           String       @id @default(cuid())
  teacherId    String       @map("teacher_id")
  subject      String
  grade        String
  topic        String?
  type         QuestionType
  difficulty   Difficulty   @default(MEDIUM)
  bloomLevel   BloomLevel   @default(UNDERSTAND)
  question     String       @db.Text
  options      Json?        // For multiple choice
  correctAnswer String?     @map("correct_answer") @db.Text
  explanation  String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Template {
  id          String      @id @default(cuid())
  teacherId   String      @map("teacher_id")
  name        String
  type        AIGenerationType
  content     Json        // The saved content
  subject     String?
  grade       String?
  methodology Methodology?
  isFavorite  Boolean     @default(false) @map("is_favorite")
  timesUsed   Int         @default(0) @map("times_used")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("templates")
}

// ==================== CLASSROOM ====================

model Classroom {
  id          String   @id @default(cuid())
  teacherId   String   @map("teacher_id")
  name        String
  subject     String
  grade       String
  group       String?  // "A", "B", etc.
  shift       String?  // "mañana", "tarde", "noche"
  academicYear String  @map("academic_year") // "2024"
  code        String   @unique // Join code like "MAT8A-4521"
  color       String   @default("#3B82F6") // Hex color for UI
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  assignments Assignment[]
  schedules   Schedule[]
  units       Unit[]
  guides      Guide[]
  exams       Exam[]
  
  // New relations for Fase 1
  gradeBooks  GradeBook[]
  attendanceRecords Attendance[]
  calendarEvents CalendarEvent[]
  teacherLogs TeacherLog[]
  recaudos    Recaudo[]

  @@map("classrooms")
}

// ==================== PEDAGOGICAL STRUCTURE ====================

model Unit {
  id          String   @id @default(cuid())
  classroomId String   @map("classroom_id")
  periodId    String?  @map("period_id")
  name        String   // "Unidad 1: Fracciones"
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  classroom   Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  period      AcademicPeriod? @relation(fields: [periodId], references: [id])
  topics      Topic[]

  @@map("units")
}

model Topic {
  id          String   @id @default(cuid())
  unitId      String   @map("unit_id")
  name        String   // "Suma de fracciones"
  description String?  @db.Text
  order       Int      @default(0)
  hours       Int      @default(2) // Horas estimadas
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  guides      Guide[]
  exams       Exam[]

  @@map("topics")
}

model Enrollment {
  id          String   @id @default(cuid())
  classroomId String   @map("classroom_id")
  studentId   String   @map("student_id")
  roles       Json?    // Array of roles: ["monitor", "delegado"]
  joinedAt    DateTime @default(now()) @map("joined_at")

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@map("enrollments")
}

model Assignment {
  id           String    @id @default(cuid())
  classroomId  String    @map("classroom_id")
  guideId      String?   @map("guide_id")
  examId       String?   @map("exam_id")
  title        String
  instructions String?   @db.Text
  dueDate      DateTime? @map("due_date")
  isPublished  Boolean   @default(false) @map("is_published")
  createdAt    DateTime  @default(now()) @map("created_at")

  classroom   Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  guide       Guide?       @relation(fields: [guideId], references: [id])
  exam        Exam?        @relation(fields: [examId], references: [id])
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           String    @id @default(cuid())
  assignmentId String    @map("assignment_id")
  studentId    String    @map("student_id")
  answers      Json?
  score        Float?
  autoGraded   Boolean   @default(false) @map("auto_graded")
  feedback     Json?
  submittedAt  DateTime  @default(now()) @map("submitted_at")
  gradedAt     DateTime? @map("graded_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

model Schedule {
  id          String   @id @default(cuid())
  classroomId String   @map("classroom_id")
  dayOfWeek   Int      @map("day_of_week") // 0-6 (Sunday-Saturday)
  startTime   String   @map("start_time") // "08:00"
  endTime     String   @map("end_time") // "09:30"
  room        String?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   // "assignment", "grade", "announcement", etc.
  actionUrl String?  @map("action_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ==================== SUBSCRIPTIONS ====================

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique @map("user_id")
  plan              Plan
  status            SubscriptionStatus @default(ACTIVE)
  provider          String             // "stripe" or "mercadopago"
  providerSubId     String?            @map("provider_sub_id")
  amount            Float
  currency          String             @default("USD")
  currentPeriodStart DateTime          @map("current_period_start")
  currentPeriodEnd   DateTime          @map("current_period_end")
  cancelAtPeriodEnd  Boolean           @default(false) @map("cancel_at_period_end")
  createdAt         DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ==================== USAGE & AI ====================

model UsageLimit {
  id             String @id @default(cuid())
  userId         String @map("user_id")
  month          Int
  year           Int
  guidesCreated  Int    @default(0) @map("guides_created")
  examsCreated   Int    @default(0) @map("exams_created")
  aiRequests     Int    @default(0) @map("ai_requests")
  questionsSaved Int    @default(0) @map("questions_saved")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("usage_limits")
}

model AIGeneration {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  type         AIGenerationType
  prompt       String           @db.Text
  result       Json
  model        String           @default("gpt-4o-mini")
  tokensInput  Int              @default(0) @map("tokens_input")
  tokensOutput Int              @default(0) @map("tokens_output")
  costUsd      Float            @default(0) @map("cost_usd")
  cached       Boolean          @default(false)
  cacheKey     String?          @map("cache_key")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_generations")
}

model AICache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique @map("cache_key")
  result    Json
  hits      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("ai_cache")
}

// ==================== FASE 1 - GESTIÓN ACADÉMICA ====================

model AcademicPeriod {
  id          String   @id @default(cuid())
  teacherId   String   @map("teacher_id")
  name        String   // "Período 1", "Bimestre 2"
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  gradeBooks  GradeBook[]
  units       Unit[]

  @@map("academic_periods")
}

model SchoolProfile {
  id            String @id @default(cuid())
  teacherId     String @unique @map("teacher_id")
  schoolName    String? @map("school_name")
  logoUrl       String? @map("logo_url")
  gradingSystem String @default("0-5") @map("grading_system") // "0-5", "0-10", "letters"
  periods       Int    @default(4)
  country       String @default("CO")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("school_profiles")
}

model GradeBook {
  id            String   @id @default(cuid())
  studentId     String   @map("student_id")
  classroomId   String   @map("classroom_id")
  academicPeriodId String? @map("academic_period_id")
  examId        String?  @map("exam_id")
  score         Float?
  maxScore      Float    @map("max_score")
  period        String   // "Q1", "Q2", "Final"
  category      String   // "exam", "participation", "homework", "project"
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  student       User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom     Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  academicPeriod AcademicPeriod? @relation(fields: [academicPeriodId], references: [id])
  exam          Exam?          @relation(fields: [examId], references: [id])

  @@map("grade_books")
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String           @map("student_id")
  classroomId String           @map("classroom_id")
  date        DateTime         @db.Date
  status      AttendanceStatus
  note        String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, classroomId, date])
  @@map("attendance")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  teacherId   String   @map("teacher_id")
  classroomId String?  @map("classroom_id")
  examId      String?  @map("exam_id")
  title       String
  date        DateTime @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  type        EventType
  color       String   @default("#3B82F6")
  allDay      Boolean  @default(false) @map("all_day")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  teacher     User       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  exam        Exam?      @relation(fields: [examId], references: [id])

  @@map("calendar_events")
}

model TeacherLog {
  id          String   @id @default(cuid())
  teacherId   String   @map("teacher_id")
  classroomId String?  @map("classroom_id")
  studentId   String?  @map("student_id")
  title       String?
  content     String   @db.Text
  tags        Json?    // Array of strings
  isPrivate   Boolean  @default(true) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")

  teacher     User       @relation("TeacherLogs", fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     User?      @relation("StudentLogs", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("teacher_logs")
}

model Recaudo {
  id          String   @id @default(cuid())
  teacherId   String   @map("teacher_id")
  classroomId String   @map("classroom_id")
  title       String
  description String?  @db.Text
  fields      Json     // Array of field definitions
  deadline    DateTime @map("deadline")
  status      String   @default("active") // active, closed, draft
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  responses   RecaudoResponse[]

  @@map("recaudos")
}

model RecaudoResponse {
  id           String   @id @default(cuid())
  recaudoId    String   @map("recaudo_id")
  studentId    String   @map("student_id")
  responses    Json     // Field responses
  submittedAt  DateTime @default(now()) @map("submitted_at")

  recaudo      Recaudo @relation(fields: [recaudoId], references: [id], onDelete: Cascade)
  student      User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([recaudoId, studentId])
  @@map("recaudo_responses")
}
